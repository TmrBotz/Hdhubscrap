# ─────────────────────────────────────────────────────
#  .env.example — Local dev ke liye template
#  cp .env.example .env  →  apni values bharo
#  KABHI .env ko Git pe push mat karo!
# ─────────────────────────────────────────────────────

# Pyrogram — https://my.telegram.org/auth
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890

# Bot Token — @BotFather se
TELEGRAM_BOT_TOKEN=1234567890:ABCDefGhIJKlmNoPQRsTUVwXYZ

# Channel — public: @MyChannel  /  private: -1001234567890
TELEGRAM_CHANNEL_ID=@MyMovieChannel

# MongoDB Atlas — https://cloud.mongodb.com
# Format: mongodb+srv://user:password@cluster.mongodb.net/
MONGO_URI=mongodb+srv://myuser:mypassword@cluster0.abcde.mongodb.net/?retryWrites=true&w=majority

# Optional
WEBSITE_URL=https://new3.hdhub4u.cl/
CHECK_INTERVAL_MINUTES=30
MAX_DL_LINKS=10
